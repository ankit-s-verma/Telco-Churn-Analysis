      <column caption='ChurnRate%' datatype='real' default-format='p0.00%' name='[Calculation_1526960364658689]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF  [Churn] = &apos;Yes&apos; THEN 1 ELSE 0 END)&#13;&#10;/&#13;&#10;COUNT([customerID])' />
